doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Mayondo Wood and Furniture Ltd
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap' rel='stylesheet')
    link(rel="stylesheet" href="css/index.css")
    style.
      /* Floating logout button */
      .logout-float {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
      }

      .logout-float .btn-logout {
        background: #dc3545;
        color: white;
        padding: 10px 20px;
        border-radius: 50px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
        font-weight: 500;
      }

      .logout-float .btn-logout:hover {
        background: #c82333;
      }

      @media (max-width: 768px) {
        .logout-float .btn-logout span {
          display: none;
        }
      }

  body
    // Floating logout button
    if currentUser
      .logout-float
        button#logoutBtn.btn-logout(type='button')
          i.fa-solid.fa-sign-out-alt
          span Logout

    header
      .decoration
        .circle
        .circle
        .circle
        .circle
      .intro
        p Welcome to
        h1 Mayondo Wood And Furniture Ltd
        if !currentUser
          a.btn(href="/login") Get Started
        else
          a.btn(href="/dashboard") Go to Dashboard
    
    section#about.animate-on-scroll
      h2 About Us
      p.
        Our mission is to deliver high quality services and products that help businesses succeed in the digital era. We focus on innovation, efficiency, and customer satisfaction.
      p.
        With years of experience in the wood and furniture industry, we pride ourselves on craftsmanship, sustainability, and attention to detail. Our team of skilled artisans transforms the finest materials into pieces that will last for generations.
    
    section.products
      h2.animate-on-scroll Our Products
      .products-grid
        .product-card.animate-on-scroll
          img(src="../images/landing1.jpeg", alt="Wood")
          h3 Premium Wood
          p High-quality timber for all your construction and carpentry needs.
        .product-card.animate-on-scroll
          img(src="../images/landing2.jpeg", alt="Furniture")
          h3 Elegant Furniture
          p Beautiful and durable furniture pieces crafted to perfection.
        .product-card.animate-on-scroll
          img(src="../images/office-three.jpeg", alt="Office Furniture")
          h3 Office Solutions
          p Stylish and ergonomic furniture designed for modern workspaces.
    
    footer
      p © 2025 Mayondo Wood & Furniture Ltd. All rights reserved.
      p Designed By Kirabo Rebecca.

    // Logout Modal
    #logoutConfirmationModal.modal.fade
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-warning
            h5.modal-title Confirm Logout
            button.btn-close(data-bs-dismiss='modal')
          .modal-body
            p Are you sure you want to logout?
          .modal-footer
            button.btn.btn-secondary(data-bs-dismiss='modal') Cancel
            a.btn.btn-danger(href='/logout') Logout

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
    script.
      // Animation for the intro section
      document.addEventListener('DOMContentLoaded', function() {
        const intro = document.querySelector('.intro');
        setTimeout(() => {
          intro.classList.add('visible');
        }, 300);
      });

      // Scroll animation for sections
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
      });

      document.querySelectorAll('.product-card').forEach((card, index) => {
        card.style.transitionDelay = `${index * 0.2}s`;
        observer.observe(card);
      });

      // Logout functionality
      document.getElementById('logoutBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        const modal = new bootstrap.Modal(document.getElementById('logoutConfirmationModal'));
        modal.show();
      });