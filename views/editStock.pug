doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Edit Stock
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap' rel='stylesheet')
    link(rel='stylesheet' href='/css/add-stock.css')
  body
    aside.side-menu-container
      .logo-menu
        h2.logo MWF
        i.fa-solid.fa-bars
      ul.list
        li.list-item
          a(href='/dashboard')
            i.fa-solid.fa-house
            span.link-name Dashboard
        li.list-item
          a(href='/usersList')
            i.fa-solid.fa-users
            span.link-name Users
        li.list-item
          a(href='/sales')
            i.fa-solid.fa-cart-shopping
            span.link-name Sales
        li.list-item.active
          a(href='/stock')
            i.fa-solid.fa-truck
            span.link-name Stock
        li.list-item
          a(href='/products')
            i.fa-solid.fa-couch
            span.link-name Products
        li.list-item
          a(href='/settings')
            i.fa-solid.fa-gear
            span.link-name Settings
    main.main-content
      nav.navbar.bg-body-tertiary.dashboard-header
        .container-fluid.d-flex.justify-content-end.align-items-center
          .d-flex.align-items-center
            a.logoutBtn(href='/index') Logout
      .stock-form-container
        //- Display success/error messages
        if success
          .alert.alert-success= success
        if error
          .alert.alert-danger= error

        form#addStock(action="/editStock/" + item._id method="post")
          h2 Edit Stock Here!
          
          label(for='pdtname') Product Name
          br
          input#pdtname(type='text' name='pdtname' required value=item.pdtname)
          br
          br
          
          label(for='pdttype') Type of Product
          br
          select#tproduct(name="pdttype" required)
            option(value=item.pdttype selected)= item.pdttype
            option(value="Raw Material") Raw Material
            option(value="Furniture") Furniture
          br
          br
          label(for='pdtquantity1') Total Quantity
          br
          input#pdtquantity1(type='number' name='pdtquantity1' required value=item.pdtquantity1)
          br
          br
          label(for='pdtquantity') Quantity
          br
          input#pdtquantity(type='number' name='pdtquantity' required value=item.pdtquantity)
          br
          br
          
          label(for='cprice') Cost Price
          br
          input#cprice(type='number' name='cprice' required step="0.01" value=item.cprice)
          br
          br
          
          label(for='pdtprice') Product Price
          br
          input#pdtprice(type='number' name='pdtprice' required step="0.01" value=item.pdtprice)
          br
          br
          
          label(for='supplier') Supplier Name
          br
          input#supplier(type='text' name='supplier' required value=item.supplier)
          br
          br
          
          label(for='supplierContact') Supplier Contact
          br
          input#supplierContact(type='text' name='supplierContact' required value=item.supplierContact)
          br
          br
          
          label(for='quality') Quality
          br
          select#quality(name="quality" required)
            option(value=item.quality selected)= item.quality
            option(value="Premium") Premium
            option(value="Good") Good
            option(value="Fair") Fair
            option(value="Poor") Poor
          br
          br
          
          label(for='date') Date
          br
          input#date(type='date' name='date' required value=item.date.toISOString().split('T')[0])
          br
          br
          
          .add
            button.btns(type='submit') Update Stock
            a.btns(href='/stock' style='text-decoration: none; color: white;') Cancel

        script(src='/javascript/sales.js')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')