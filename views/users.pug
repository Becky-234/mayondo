extends layout.pug 

block styles
  link(rel="stylesheet", href="/css/user.css")  

block content 
  // SUCCESS MODAL
  if success
    .modal.fade.show(tabindex='-1', style='display: block; background-color: rgba(0,0,0,0.5);')
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-success.text-white
            h5.modal-title
              i.fas.fa-check-circle.me-2
              | Success!
            button.btn-close(type='button', onclick="closeMessageModal()")
          .modal-body
            p #{success}
          .modal-footer
            button.btn.btn-success(type='button', onclick="closeMessageModal()") OK

  // ERROR MODAL
  if error
    .modal.fade.show(tabindex='-1', style='display: block; background-color: rgba(0,0,0,0.5);')
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-danger.text-white
            h5.modal-title
              i.fas.fa-exclamation-circle.me-2
              | Error!
            button.btn-close(type='button', onclick="closeMessageModal()")
          .modal-body
            p #{error}
          .modal-footer
            button.btn.btn-danger(type='button', onclick="closeMessageModal()") OK

  // DELETE CONFIRMATION MODAL
  #deleteConfirmationModal.modal.fade(tabindex='-1', aria-labelledby='deleteConfirmationModalLabel', aria-hidden='true')
    .modal-dialog.modal-dialog-centered
      .modal-content
        .modal-header.bg-warning.text-dark
          h5#deleteConfirmationModalLabel.modal-title
            i.fas.fa-exclamation-triangle.me-2
            | Confirm Deletion
          button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
        .modal-body
          p#deleteModalText Are you sure you want to delete this user?
          p.text-muted.small This action cannot be undone.
        .modal-footer
          button.btn.btn-secondary(type='button', data-bs-dismiss='modal') Cancel
          button#confirmDeleteBtn.btn.btn-danger(type='button') Delete

  // HIDDEN INPUT FOR USER ID
  input#deleteUserId(type='hidden')
  
  .to-do
    .button-group
      a#newUser.btns(href="/addUser")
        i.fas.fa-user-plus
        | Add New User
      a#downloadExcel.btns
        i.fas.fa-file-excel
        | Download Excel
      a#downloadPdf.btns
        i.fas.fa-file-pdf
        | Download PDF
    input#searchUser(type="search", placeholder="Search users...") 
  
  .table-container
    table#usersTable.table-content
      thead
        tr
          th Full Name
          th Email
          th Phone Number
          th NIN
          th Address
          th Username 
          th Date
          th Actions 
      tbody#usersTableBody
        //- Table body will be populated by JavaScript for pagination
    
    //- Pagination Controls
    .pagination-container
      .pagination-info
        span Showing 
        span#showingStart 0
        span  to 
        span#showingEnd 0
        span  of 
        span#totalRecords 0
        span  entries
      .pagination-controls
        button#prevPage.pagination-btn(type='button', disabled)
          i.fas.fa-chevron-left
          | Previous
        .pagination-pages
          //- Page numbers will be dynamically generated here
        button#nextPage.pagination-btn(type='button', disabled)
          | Next
          i.fas.fa-chevron-right
  
  h5#notFound Not Found

  footer
    p © 2025 Mayondo Wood & Furniture Ltd. All rights reserved.
    p Designed By Kirabo Rebecca

  script(src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js")
  script(src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js")
  script(src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js")
  
  script.
    // User data passed from server
    const usersData = !{JSON.stringify(users)};
    
    // Pagination variables
    let currentPage = 1;
    const rowsPerPage = 10;
    let filteredData = [...usersData];
    let currentDeleteId = null;
    let currentDeleteName = '';
    
    // Function to render table with pagination
    function renderTable() {
      const startIndex = (currentPage - 1) * rowsPerPage;
      const endIndex = Math.min(startIndex + rowsPerPage, filteredData.length);
      const pageData = filteredData.slice(startIndex, endIndex);
      
      const tbody = document.getElementById('usersTableBody');
      tbody.innerHTML = '';
      
      if (pageData.length === 0) {
        tbody.innerHTML = `<tr><td colspan="8" style="text-align: center;">No users found</td></tr>`;
        document.getElementById('notFound').style.display = 'block';
      } else {
        document.getElementById('notFound').style.display = 'none';
        
        pageData.forEach(user => {
          const row = tbody.insertRow();
          
          row.insertCell(0).textContent = user.name || '';
          row.insertCell(1).textContent = user.email || '';
          row.insertCell(2).textContent = user.tel ? '+256' + user.tel : '';
          row.insertCell(3).textContent = user.nin || '';
          row.insertCell(4).textContent = user.address || '';
          row.insertCell(5).textContent = user.username || '';
          row.insertCell(6).textContent = user.date ? new Date(user.date).toLocaleDateString() : '';
          
          const actionsCell = row.insertCell(7);
          actionsCell.className = 'actions';
          
          // Edit button
          const editBtn = document.createElement('a');
          editBtn.href = `/editUser/${user._id}`;
          editBtn.className = 'btn-icon';
          editBtn.title = 'Edit';
          editBtn.innerHTML = '<i class="fas fa-edit"></i>';
          actionsCell.appendChild(editBtn);
          
          // Delete button
          const deleteBtn = document.createElement('button');
          deleteBtn.className = 'btn-icon';
          deleteBtn.title = 'Delete';
          deleteBtn.type = 'button';
          deleteBtn.onclick = () => showDeleteModal(user._id, user.name);
          deleteBtn.innerHTML = '<i class="fas fa-trash"></i>';
          actionsCell.appendChild(deleteBtn);
        });
      }
      
      // Update pagination info
      updatePaginationInfo();
      updatePaginationButtons();
    }
    
    // Update pagination info text
    function updatePaginationInfo() {
      const totalRecords = filteredData.length;
      const startIndex = (currentPage - 1) * rowsPerPage + 1;
      const endIndex = Math.min(startIndex + rowsPerPage - 1, totalRecords);
      
      document.getElementById('showingStart').textContent = totalRecords === 0 ? 0 : startIndex;
      document.getElementById('showingEnd').textContent = endIndex;
      document.getElementById('totalRecords').textContent = totalRecords;
    }
    
    // Update pagination buttons
    function updatePaginationButtons() {
      const totalPages = Math.ceil(filteredData.length / rowsPerPage);
      
      const prevBtn = document.getElementById('prevPage');
      const nextBtn = document.getElementById('nextPage');
      
      prevBtn.disabled = currentPage === 1;
      nextBtn.disabled = currentPage === totalPages || totalPages === 0;
      
      const paginationPages = document.querySelector('.pagination-pages');
      paginationPages.innerHTML = '';
      
      if (totalPages === 0) {
        paginationPages.innerHTML = '<span class="pagination-ellipsis">No pages</span>';
        return;
      }
      
      let startPage = Math.max(1, currentPage - 2);
      let endPage = Math.min(totalPages, startPage + 4);
      
      if (endPage - startPage < 4) {
        startPage = Math.max(1, endPage - 4);
      }
      
      if (startPage > 1) {
        const firstBtn = document.createElement('button');
        firstBtn.className = 'pagination-num';
        firstBtn.textContent = '1';
        firstBtn.onclick = () => goToPage(1);
        paginationPages.appendChild(firstBtn);
        
        if (startPage > 2) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'pagination-ellipsis';
          ellipsis.textContent = '...';
          paginationPages.appendChild(ellipsis);
        }
      }
      
      for (let i = startPage; i <= endPage; i++) {
        const pageBtn = document.createElement('button');
        pageBtn.className = 'pagination-num';
        if (i === currentPage) pageBtn.classList.add('active');
        pageBtn.textContent = i;
        pageBtn.onclick = () => goToPage(i);
        paginationPages.appendChild(pageBtn);
      }
      
      if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'pagination-ellipsis';
          ellipsis.textContent = '...';
          paginationPages.appendChild(ellipsis);
        }
        
        const lastBtn = document.createElement('button');
        lastBtn.className = 'pagination-num';
        lastBtn.textContent = totalPages;
        lastBtn.onclick = () => goToPage(totalPages);
        paginationPages.appendChild(lastBtn);
      }
    }
    
    function goToPage(page) {
      const totalPages = Math.ceil(filteredData.length / rowsPerPage);
      if (page < 1 || page > totalPages) return;
      currentPage = page;
      renderTable();
    }
    
    function applySearch() {
      const searchTerm = document.getElementById('searchUser').value.toLowerCase();
      
      if (searchTerm) {
        filteredData = usersData.filter(user => 
          (user.name && user.name.toLowerCase().includes(searchTerm)) ||
          (user.email && user.email.toLowerCase().includes(searchTerm)) ||
          (user.username && user.username.toLowerCase().includes(searchTerm)) ||
          (user.nin && user.nin.toLowerCase().includes(searchTerm)) ||
          (user.address && user.address.toLowerCase().includes(searchTerm))
        );
      } else {
        filteredData = [...usersData];
      }
      
      currentPage = 1;
      renderTable();
    }
    
    function showDeleteModal(userId, userName) {
      currentDeleteId = userId;
      currentDeleteName = userName;
      document.getElementById('deleteModalText').innerHTML = `Are you sure you want to delete user <strong>${userName}</strong>?`;
      document.getElementById('deleteUserId').value = userId;
      
      const modalElement = document.getElementById('deleteConfirmationModal');
      const modal = new bootstrap.Modal(modalElement);
      modal.show();
    }
    
    function closeMessageModal() {
      const modal = document.querySelector('.modal.show');
      if (modal) modal.remove();
      window.location.href = '/usersList';
    }
    
    // Event listeners
    document.getElementById('searchUser').addEventListener('input', applySearch);
    
    document.getElementById('prevPage').addEventListener('click', () => {
      if (currentPage > 1) goToPage(currentPage - 1);
    });
    
    document.getElementById('nextPage').addEventListener('click', () => {
      const totalPages = Math.ceil(filteredData.length / rowsPerPage);
      if (currentPage < totalPages) goToPage(currentPage + 1);
    });
    
    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
      if (currentDeleteId) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/deleteUser/${currentDeleteId}`;
        form.style.display = 'inline';
        document.body.appendChild(form);
        form.submit();
      }
    });
    
    // PDF Download
    document.getElementById('downloadPdf').addEventListener('click', function() {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF({ orientation: 'landscape' });
      
      const tableColumn = ["Full Name", "Email", "Phone Number", "NIN", "Address", "Username", "Date"];
      
      const tableRows = filteredData.map(user => [
        user.name || '',
        user.email || '',
        user.tel ? '+256' + user.tel : '',
        user.nin || '',
        user.address || '',
        user.username || '',
        user.date ? new Date(user.date).toLocaleDateString() : ''
      ]);
      
      doc.autoTable({
        head: [tableColumn],
        body: tableRows,
        startY: 20,
        theme: 'striped',
        headStyles: { fillColor: [76, 100, 68], textColor: 255 },
        styles: { fontSize: 9, cellPadding: 2 }
      });
      
      doc.text("Users Report", 14, 10);
      doc.save('users_report.pdf');
    });
    
    // Excel Download
    document.getElementById('downloadExcel').addEventListener('click', function() {
      const wsData = filteredData.map(user => ({
        'Full Name': user.name,
        'Email': user.email,
        'Phone Number': user.tel ? '+256' + user.tel : '',
        'NIN': user.nin,
        'Address': user.address,
        'Username': user.username,
        'Date': user.date ? new Date(user.date).toLocaleDateString() : ''
      }));
      
      const ws = XLSX.utils.json_to_sheet(wsData);
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Users Data');
      XLSX.writeFile(wb, 'users_data.xlsx');
    });
    
    // Initial render
    renderTable();