doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Mayondo Wood and Furniture Ltd
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap' rel='stylesheet')
    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Poppins', sans-serif;
      }
      
      body {
        display: flex;
        background: #f4f6f9;
        min-height: 100vh;
      }
      
      /* SIDE BAR WITH FOLDING FEATURE */
      .side-menu-container {
        width: 280px;
        background: #4c6444;
        height: 100vh;
        position: sticky;
        top: 0;
        flex-shrink: 0;
        overflow-y: auto;
        transition: width 0.5s;
      }
      
      .side-menu-container.collapsed {
        width: 80px;
      }
      
      .logo-menu {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        transition: all 0.3s;
      }
      
      .side-menu-container.collapsed .logo-menu {
        justify-content: center;
        padding: 20px 0;
      }
      
      .logo-menu .logo {
        font-size: 28px;
        color: #fff;
        font-weight: 700;
        white-space: nowrap;
        transition: all 0.3s;
      }
      
      .side-menu-container.collapsed .logo-menu .logo {
        display: none;
      }
      
      .logo-menu .fa-bars {
        font-size: 25px;
        color: #fff;
        cursor: pointer;
      }
      
      .side-menu-container.collapsed .logo-menu .fa-bars {
        margin: 0 auto;
      }
      
      .list {
        list-style: none;
        padding: 20px 0;
      }
      
      .list-item {
        margin: 5px 0;
      }
      
      .side-menu-container .list-item a {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        color: #fff;
        text-decoration: none;
        gap: 15px;
        transition: all 0.3s;
        border-radius: 6px;
      }
      
      .side-menu-container .list-item a i {
        width: 25px;
        font-size: 18px;
        text-align: center;
      }
      
      .side-menu-container.collapsed .list-item a {
        justify-content: center;
        padding: 12px 0;
      }
      
      .side-menu-container.collapsed .list-item a i {
        margin: 0;
        font-size: 22px;
      }
      
      .side-menu-container.collapsed .list-item a .link-name {
        display: none;
      }
      
      .list-item a:hover {
        background: rgba(255,255,255,0.2);
        padding-left: 25px;
      }
      
      .side-menu-container.collapsed .list-item a:hover {
        padding-left: 0;
      }
      
      /* Main Content */
      .main-content {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        height: 100vh;
      }

      /* Floating logout button - ADD THIS */
      .logout-float {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
      }

      .logout-float .btn-logout {
        background: #dc3545;
        color: white;
        padding: 10px 20px;
        border-radius: 50px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        border: none;
        cursor: pointer;
        font-weight: 500;
      }

      .logout-float .btn-logout:hover {
        background: #c82333;
      }

      @media (max-width: 768px) {
        .logout-float .btn-logout span {
          display: none;
        }
      }
    block styles

  body
    // FLOATING LOGOUT BUTTON - ADD THIS RIGHT AFTER BODY TAG
    if currentUser
      .logout-float
        button#logoutBtn.btn-logout(type='button')
          i.fa-solid.fa-sign-out-alt
          span Logout

    if currentUser
      aside.side-menu-container
        .logo-menu
          h2.logo MWF
          i.fa-solid.fa-bars
        ul.list
          if currentUser.role === "manager" || currentUser.role === "Manager" || currentUser.isManager === true
            li.list-item
              a(href='/dashboard')
                i.fa-solid.fa-house
                span.link-name Dashboard
            li.list-item
              a(href='/usersList')
                i.fa-solid.fa-users
                span.link-name Users
          li.list-item
            a(href='/sales')
              i.fa-solid.fa-cart-shopping
              span.link-name Sales
          li.list-item
            a(href='/stock')
              i.fa-solid.fa-truck
              span.link-name Stock
          li.list-item
            a(href='/products')
              i.fa-solid.fa-couch
              span.link-name Products
      .main-content
        block content
    else
      block content

    // Logout Modal
    #logoutConfirmationModal.modal.fade
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-warning
            h5.modal-title Confirm Logout
            button.btn-close(data-bs-dismiss='modal')
          .modal-body
            p Are you sure you want to logout?
          .modal-footer
            button.btn.btn-secondary(data-bs-dismiss='modal') Cancel
            a.btn.btn-danger(href='/logout') Logout

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
    script.
      // Sidebar folding feature
      const toggleBtn = document.querySelector('.logo-menu .fa-bars');
      const sidebar = document.querySelector('.side-menu-container');
      
      if (toggleBtn && sidebar) {
        toggleBtn.addEventListener('click', function() {
          sidebar.classList.toggle('collapsed');
        });
      }
      
      // Logout functionality - FIXED
      document.getElementById('logoutBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        const modal = new bootstrap.Modal(document.getElementById('logoutConfirmationModal'));
        modal.show();
      });
    block scripts