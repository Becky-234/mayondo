doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Mayondo Wood and Furniture Ltd
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css')
    link(href='https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap' rel='stylesheet')
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
      body { display: flex; background: #f4f6f9; min-height: 100vh; }
      .side-menu-container { width: 280px; background: #4c6444; height: 100vh; position: sticky; top: 0; flex-shrink: 0; }
      .logo-menu { padding: 20px; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.2); }
      .logo-menu .logo { font-size: 28px; color: #fff; font-weight: 700; }
      .list { list-style: none; padding: 20px 0; }
      .list-item { margin: 5px 0; }
      .list-item a { display: flex; align-items: center; padding: 12px 20px; color: #fff; text-decoration: none; gap: 15px; transition: all 0.3s; }
      .list-item a:hover { background: rgba(255,255,255,0.2); padding-left: 25px; }
      .list-item a i { width: 25px; font-size: 18px; }
      .main-content { flex: 1; padding: 20px; overflow-y: auto; }
    block styles

  body
    if currentUser
      aside.side-menu-container
        .logo-menu
          h2.logo MWF
        ul.list
          if currentUser.role === "manager" || currentUser.role === "Manager"
            li.list-item: a(href='/dashboard') <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
            li.list-item: a(href='/usersList') <i class="fas fa-users"></i> <span>Users</span>
          li.list-item: a(href='/sales') <i class="fas fa-shopping-cart"></i> <span>Sales</span>
          li.list-item: a(href='/stock') <i class="fas fa-boxes"></i> <span>Stock</span>
          li.list-item: a(href='/products') <i class="fas fa-couch"></i> <span>Products</span>
          li.list-item: a#logoutBtn(href='#') <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
      .main-content
        block content
    else
      block content

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
    script.
      document.getElementById('logoutBtn')?.addEventListener('click', function(e) {
        e.preventDefault();
        if(confirm('Are you sure you want to logout?')) window.location.href='/logout';
      });