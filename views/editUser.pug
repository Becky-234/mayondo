extends layout.pug 

block styles 
  link(rel='stylesheet' href='/css/add-user.css')
  
block content 
  main.main-content
    .user-form-container
      .form-header
        h2
          i.fas.fa-user-edit
          | Edit Sales Agent
        p.instruction Update the sales agent account details

      form#editUser(action=`/editUser/${user._id}` method='post' novalidate)
        .form-grid
          if error
            .alert.alert-danger
              i.fas.fa-exclamation-circle
              | #{error}
          
          .form-group
            label(for='name')
              i.fas.fa-user
              | Full Name
            input#name.form-control(type='text' name='name' value=user.name required)
            .error-message#name-error Please enter a valid full name (2-100 characters)
          
          .form-group
            label(for='email')
              i.fas.fa-envelope
              | Email Address
            input#email.form-control(type="email", name="email", value=user.email required)
            .error-message#email-error Please enter a valid email address
          
          .form-group
            label(for='tel')
              i.fas.fa-phone
              | Phone Number
            input#tel.form-control(type="text", name="tel", value=user.tel required)
            .error-message#tel-error Please enter a valid phone number (9-10 digits)
          
          .form-group
            label(for='nin')
              i.fas.fa-id-card
              | NIN Number
            input#nin.form-control(type='text' name='nin' value=user.nin required)
            .error-message#nin-error Please enter a valid NIN number
          
          .form-group
            label(for='address')
              i.fas.fa-home
              | Address
            input#address.form-control(type='text' name='address' value=user.address required)
            .error-message#address-error Please enter a valid address
          
          .form-group
            label(for='username')
              i.fas.fa-user-circle
              | Username
            input#username.form-control(type='text' name='username' value=user.username required)
            .error-message#username-error Please enter a username (3-20 characters)
          
          .form-group
            label(for='password')
              i.fas.fa-lock
              | Password
              small.text-muted (Leave blank to keep current password)
            input#password.form-control(type='password' name='password' placeholder='Enter new password or leave blank')
            .error-message#password-error Password must be at least 6 characters
            .password-strength
              .strength-bar#passwordStrength
          
          .form-group
            label(for='confirmPassword')
              i.fas.fa-lock
              | Confirm Password
            input#confirmPassword.form-control(type='password' name='confirmPassword' placeholder='Confirm new password')
            .error-message#confirmPassword-error Passwords do not match
          
          .form-group
            label(for='date')
              i.fas.fa-calendar-alt
              | Registration Date
            input#date.form-control(type='date' name='date' value=user.date ? user.date.toISOString().split('T')[0] : '' required)
            .error-message#date-error Please select a valid date
        
        .form-actions
          a.btn.btn-secondary(href='/usersList' style='text-decoration: none;')
            i.fas.fa-times
            | Cancel
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            | Update User

  script.
    document.addEventListener('DOMContentLoaded', function() {
      console.log('DOM loaded - validation starting');
      
      const form = document.getElementById('editUser');
      const passwordInput = document.getElementById('password');
      const confirmPasswordInput = document.getElementById('confirmPassword');
      const passwordStrength = document.getElementById('passwordStrength');

      if (!form) {
        console.error('Form not found!');
        return;
      }

      console.log('Form found');

      // Password strength indicator (only if password is entered)
      if (passwordInput && passwordStrength) {
        passwordInput.addEventListener('input', function() {
          const password = this.value;
          
          if (password.length === 0) {
            passwordStrength.className = 'strength-bar';
            passwordStrength.style.width = '0%';
            return;
          }
          
          let strength = 0;
          
          if (password.length >= 6) strength++;
          if (password.length >= 8) strength++;
          if (/[A-Z]/.test(password)) strength++;
          if (/[0-9]/.test(password)) strength++;
          if (/[^A-Za-z0-9]/.test(password)) strength++;
          
          passwordStrength.className = 'strength-bar';
          
          if (strength <= 2) {
            passwordStrength.classList.add('strength-weak');
          } else if (strength <= 4) {
            passwordStrength.classList.add('strength-medium');
          } else {
            passwordStrength.classList.add('strength-strong');
          }
        });
      }

      // Enhanced validation functions
      const validators = {
        name: (value) => value.trim().length >= 2 && value.trim().length <= 100,
        email: (value) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim()),
        tel: (value) => {
          const cleanValue = value.replace(/\s+/g, '');
          return /^(\+?256|0)?[0-9]{9}$/.test(cleanValue);
        },
        nin: (value) => value.trim().length >= 10 && value.trim().length <= 14,
        address: (value) => value.trim().length >= 5 && value.trim().length <= 200,
        username: (value) => value.trim().length >= 3 && value.trim().length <= 20 && /^[a-zA-Z0-9_]+$/.test(value),
        password: (value) => {
          // Password is optional on edit - only validate if entered
          if (value.length === 0) return true;
          return value.length >= 6;
        },
        confirmPassword: (value) => {
          const password = document.getElementById('password').value;
          // If password is empty, confirm password should also be empty
          if (password.length === 0 && value.length === 0) return true;
          // If password is entered, confirm must match
          return value === password;
        },
        date: (value) => value && !isNaN(new Date(value).getTime())
      };

      // Error messages
      const errorMessages = {
        name: "Please enter a valid full name (2-100 characters)",
        email: "Please enter a valid email address",
        tel: "Please enter a valid phone number (9-10 digits)",
        nin: "Please enter a valid NIN number (10-14 characters)",
        address: "Please enter a valid address (5-200 characters)",
        username: "Username must be 3-20 characters (letters, numbers, underscores only)",
        password: "Password must be at least 6 characters",
        confirmPassword: "Passwords do not match",
        date: "Please select a valid date"
      };

      // Show error function
      function showError(fieldName, message) {
        const field = document.getElementById(fieldName);
        const errorElement = document.getElementById(fieldName + '-error');
        
        if (field && errorElement) {
          field.classList.add('is-invalid');
          field.classList.remove('is-valid');
          errorElement.textContent = message;
          errorElement.style.display = 'block';
        }
      }

      // Show success function
      function showSuccess(fieldName) {
        const field = document.getElementById(fieldName);
        const errorElement = document.getElementById(fieldName + '-error');
        
        if (field && errorElement) {
          field.classList.remove('is-invalid');
          field.classList.add('is-valid');
          errorElement.style.display = 'none';
        }
      }

      // Validate single field
      function validateField(fieldName) {
        const field = document.getElementById(fieldName);
        if (!field) return true;

        const value = field.value;
        const isValid = validators[fieldName](value);

        if (!isValid) {
          showError(fieldName, errorMessages[fieldName]);
          return false;
        } else {
          showSuccess(fieldName);
          return true;
        }
      }

      // Validate entire form
      function validateForm() {
        let isValid = true;
        const fields = ['name', 'email', 'tel', 'nin', 'address', 'username', 'date'];
        
        // Validate required fields
        fields.forEach(fieldName => {
          if (!validateField(fieldName)) {
            isValid = false;
          }
        });
        
        // Validate password only if entered
        const password = passwordInput.value;
        if (password.length > 0) {
          if (!validateField('password')) {
            isValid = false;
          }
          if (!validateField('confirmPassword')) {
            isValid = false;
          }
        } else {
          // Clear any password validation styles if password is empty
          if (passwordInput) {
            passwordInput.classList.remove('is-invalid', 'is-valid');
            const passwordError = document.getElementById('password-error');
            if (passwordError) passwordError.style.display = 'none';
          }
          if (confirmPasswordInput) {
            confirmPasswordInput.classList.remove('is-invalid', 'is-valid');
            const confirmError = document.getElementById('confirmPassword-error');
            if (confirmError) confirmError.style.display = 'none';
          }
        }

        return isValid;
      }

      // Form submit handler
      form.addEventListener('submit', function(e) {
        console.log('Submit event triggered');
        
        if (!validateForm()) {
          e.preventDefault();
          console.log('Form validation failed - preventing submit');
          
          // Scroll to first error
          const firstError = form.querySelector('.is-invalid');
          if (firstError) {
            firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            firstError.focus();
          }
        } else {
          console.log('Form validation passed');
        }
      });

      // Real-time validation as user types
      const inputs = form.querySelectorAll('input');
      inputs.forEach(input => {
        input.addEventListener('blur', function() {
          validateField(this.id);
        });
        
        input.addEventListener('input', function() {
          if (this.classList.contains('is-invalid')) {
            validateField(this.id);
          }
        });
      });

      // Special handling for confirm password
      if (confirmPasswordInput) {
        confirmPasswordInput.addEventListener('input', function() {
          if (passwordInput.value.length > 0) {
            validateField('confirmPassword');
          }
        });
      }

      console.log('Form validation initialized successfully');
    });