extends layout.pug 

block styles
  link(rel="stylesheet", href="../css/add-sale.css")
  
block content 
  include sidebar.pug
  main.main-content
    nav.navbar.bg-body-tertiary.dashboard-header
      .container-fluid.d-flex.justify-content-end.align-items-center
        .d-flex.align-items-center
          a.logoutBtn(href="/index") Logout 
    
    // SUCCESS/ERROR MESSAGES
    if success
      .container.mt-3
        .alert.alert-success.alert-dismissible.fade.show(role="alert" style="max-width: 600px; margin: 0 auto;")
          i.fas.fa-check-circle.me-2
          strong Success! 
          | #{success}
          button.btn-close(type="button" data-bs-dismiss="alert")
    
    if error
      .container.mt-3
        .alert.alert-danger.alert-dismissible.fade.show(role="alert" style="max-width: 600px; margin: 0 auto;")
          i.fas.fa-exclamation-circle.me-2
          strong Error! 
          | #{error}
          button.btn-close(type="button" data-bs-dismiss="alert")
    
    // STOCK ALERT BANNER (Top of page)
    if lowStockItems && lowStockItems.length > 0
      .container.mt-3
        .alert.alert-warning.d-flex.align-items-center.w-50.mx-auto 
          i.fas.fa-exclamation-triangle.me-2
          strong Stock Alert: 
          | #{lowStockItems.length} product(s) are running low on stock.
    
    .user-form-container
      form#addSale(action="/addSale", method="post" novalidate)  
        h2 Add Sale Here!
        
        .form-group
          label(for="name") Name of Customer
          br
          input#name.form-control(type="text", name="name", required)
          .error-message#name-error Please enter a valid customer name (2-100 characters)
          br
        
        .form-group
          label(for="contact") Customer Contact
          br
          input#contact.form-control(type="text", name="contact", required, pattern="[0-9+\-\s()]{10,}")
          .error-message#contact-error Please enter a valid phone number (at least 10 digits)
          br
        
        .form-group
          label(for="nproduct") Name of Product
          br
          select#nproduct.form-control(name="nproduct", required, onchange="updateStockAlert()")
            option(value="", disabled, selected) Select Product
            if products && products.length
              each product in products
                option(
                  value=product.pdtname, 
                  data-stock-quantity=product.availableQuantity,
                  data-stock-status=product.stockStatus,
                  data-alert-message=product.alertMessage,
                  data-product-type=product.pdttype,
                  data-unit-price=product.unitPrice,
                  disabled=(product.stockStatus === "out-of-stock")
                )= product.pdtname + (product.stockStatus === "out-of-stock" ? " - OUT OF STOCK" : ` (Available: ${product.availableQuantity}, Price: ${Math.round(product.unitPrice).toLocaleString()} UGX)`)
            else
              option(value="", disabled) No products available
          .error-message#nproduct-error Please select a product
          br

          // STOCK ALERT DISPLAY (Dynamic - appears after product selection)
          #stockAlertContainer.mt-2(style="display: none;")
            .stock-alert#stockAlert
          br
        
        .form-group
          label(for="tproduct") Type of Product
          br
          select#tproduct.form-control(name="tproduct", required)
            option(value="", disabled, selected) Select Type of Product 
            option(value="Raw") Raw Products 
            option(value="Furniture") Furniture Products 
          .error-message#tproduct-error Please select a product type
          br
        
        .form-group
          label(for="quantity") Quantity
          br
          input#quantity.form-control(type="number", name="quantity", required, min="1")
          .error-message#quantity-error Please enter a valid quantity (minimum 1)
          br
        
        .form-group
          label(for="unitPrice") Unit Price (UGX)
          br
          input#unitPrice.form-control(type="text", name="unitPrice", required)
          .error-message#unitPrice-error Please enter a valid unit price
          br
        
        .form-group
          .form-check
            label.form-check-label(for="transportCheck" style= "margin-left: -19px") Add 5% Transport Fee 
            input#transportCheck.form-check-input(type="checkbox" name="transportCheck")
          br
          br
        
        .form-group
          label(for="totalPrice") Total Price (UGX)
          br
          input#totalPrice.form-control(type="text", name="totalPrice", required readonly)
          .error-message#totalPrice-error Total price calculation error
          br
        
        .form-group
          label(for="payment") Select Payment Method
          br
          select#payment.form-control(name="payment", required)
            option(value="", disabled, selected) Select Payment Method
            option(value="Bank Overdraft") Bank Overdraft 
            option(value="Cash") Cash
            option(value="Cheque") Cheque
          .error-message#payment-error Please select a payment method
          br
        
        .form-group
          label(for="date") Date
          br
          input#date.form-control(type="date", name="date", required)
          .error-message#date-error Please select a valid date
          br
        
        .add
          button.btns(type="submit") Save
          button.btns(type="reset" id="resetBtn") Cancel
  script(src="../javascript/sales.js")
  script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js", integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI", crossorigin="anonymous")