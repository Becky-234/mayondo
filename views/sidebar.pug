aside.side-menu-container
  .logo-menu
    h2.logo MWF
    i.fa-solid.fa-bars
  ul.list
    // Manager-only links
    if currentUser.role === "manager" || currentUser.role === "Manager" || currentUser.isManager === true
      li.list-item
        a(href='/dashboard')
          i.fa-solid.fa-house
          span.link-name Dashboard
      li.list-item
        a(href='/usersList')
          i.fa-solid.fa-users
          span.link-name Users
    
    // Common links for all logged-in users
    li.list-item
      a(href='/sales')
        i.fa-solid.fa-cart-shopping
        span.link-name Sales
    li.list-item
      a(href='/stock')
        i.fa-solid.fa-truck
        span.link-name Stock
    li.list-item
      a(href='/products')
        i.fa-solid.fa-couch
        span.link-name Products
    li.list-item
      a#logoutBtn(href='#', style='cursor: pointer;')
        i.fa-solid.fa-arrow-right-from-bracket
        span.link-name Logout

//- Logout Confirmation Modal
#logoutConfirmationModal.modal.fade(tabindex='-1', aria-labelledby='logoutConfirmationModalLabel', aria-hidden='true')
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header.bg-warning.text-dark
        h5#logoutConfirmationModalLabel.modal-title
          i.fas.fa-exclamation-triangle.me-2
          | Confirm Logout
        button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
      .modal-body
        p Are you sure you want to logout?
      .modal-footer
        button.btn.btn-secondary(type='button', data-bs-dismiss='modal')
          i.fas.fa-times
          | Cancel
        a#confirmLogoutBtn.btn.btn-danger(href='/logout')
          i.fas.fa-sign-out-alt
          | Logout

script.
  document.addEventListener('DOMContentLoaded', function() {
    const logoutBtn = document.getElementById('logoutBtn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', function(e) {
        e.preventDefault();
        const logoutModal = new bootstrap.Modal(document.getElementById('logoutConfirmationModal'));
        logoutModal.show();
      });
    }
  });