meta(charset="UTF-8")
meta(name="viewport", content="width=device-width,initial-scale=1")
title Login
link(rel="stylesheet", href="../css/login.css")
form#loginForm(action="/login", method="post")
  .form-container
    h1.head Login
    br
    .input-box
      input#email(type="email", placeholder="Email", name="email")
      span#emailError.error
    .input-box
      input#password(type="password", placeholder="Password", name="password")
      span#passwordError.error
    br
    br
    .remember-forgot
      label
        input(type="checkbox")
        | Remember Me
      a(href="#") Forgot Password?
    br
    br
    button.button#login-btn(type="submit") Login
    br

script.
  console.log("=== DEBUG ===");
  console.log("Form:", document.getElementById('loginForm'));

script(src="../javascript/login.js")