extends layout.pug 
block styles 
  link(rel='stylesheet' href='../css/add-user.css')
block content 
  include sidebar.pug
  main.main-content
    //- nav.navbar.bg-body-tertiary.dashboard-header
    //-   .container-fluid.d-flex.justify-content-end.align-items-center
    //-     .d-flex.align-items-center
    //-       a.logoutBtn(href='/index') Logout
    .user-form-container
      form#addUser(action='/add' method='post' novalidate)
        h2 Register New Sales Agent
        if error
          .alert.alert-danger(style="color: red; padding: 10px; margin-bottom: 15px; border: 1px solid red; background-color: #f8d7da;") 
          | #{error} 
        .form-group
          label(for='name') Full Name
          input#name.form-control(type='text' name='name' required)
          .error-message#name-error Please enter a valid full name (2-100 characters)
          br
        .form-group
          label(for='email') Email
          input#email.form-control(type="email", name="email", required)
          .error-message#email-error Please enter a valid email address
          br
        .form-group
          label(for='tel') Phone Number
          input#tel.form-control(type="text", name="tel", required)
          .error-message#tel-error Please enter a valid phone number (9-10 digits)
          br
        .form-group
          label(for='nin') NIN Number
          input#nin.form-control(type='text' name='nin' required)
          .error-message#nin-error Please enter a valid NIN number
          br
        .form-group
          label(for='address') Address
          input#address.form-control(type='text' name='address' required)
          .error-message#address-error Please enter a valid address
          br
        .form-group
          label(for='username') Username
          input#username.form-control(type='text' name='username' required)
          .error-message#username-error Please enter a username (3-20 characters)
          br
        .form-group
          label(for='password') Password
          input#password.form-control(type='password' name='password' required)
          .error-message#password-error Password must be at least 6 characters
          br
        .form-group
          label(for='confirmPassword') Confirm Password
          input#confirmPassword.form-control(type='password' name='confirmPassword' required)
          .error-message#confirmPassword-error Passwords do not match
          br
        .form-group
          label(for='date') Date 
          input#date.form-control(type='date' name='date' required)
          .error-message#date-error Please select a valid date
          br
        
        .add
          button.btns(type='submit') Create Sales Agent
          button.btns(type='reset' id='resetBtn') Cancel

  script.
    document.addEventListener('DOMContentLoaded', function() {
      console.log('DOM loaded - validation starting');
      
      const form = document.getElementById('addUser');
      const resetBtn = document.getElementById('resetBtn');

      if (!form) {
        console.error('Form not found!');
        return;
      }

      console.log('Form found');

      // Simple validation function that shows errors immediately
      function validateFormOnSubmit() {
        console.log('Validating form on submit...');
        let isValid = true;

        // Check each required field
        const fields = [
          'name', 'email', 'tel', 'nin', 'address', 
          'username', 'password', 'confirmPassword', 'date'
        ];

        fields.forEach(fieldName => {
          const field = document.getElementById(fieldName);
          const errorElement = document.getElementById(fieldName + '-error');
          
          if (field && errorElement) {
            const value = field.value.trim();
            
            // Simple required field validation
            if (!value) {
              field.classList.add('is-invalid');
              field.classList.remove('is-valid');
              errorElement.style.display = 'block';
              isValid = false;
              console.log('Field invalid:', fieldName);
            } else {
              field.classList.remove('is-invalid');
              field.classList.add('is-valid');
              errorElement.style.display = 'none';
            }
          }
        });

        // Additional validations
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');
        const passwordError = document.getElementById('password-error');
        const confirmError = document.getElementById('confirmPassword-error');

        if (password && password.value.length < 6) {
          password.classList.add('is-invalid');
          passwordError.style.display = 'block';
          isValid = false;
        }

        if (confirmPassword && password && confirmPassword.value !== password.value) {
          confirmPassword.classList.add('is-invalid');
          confirmError.style.display = 'block';
          isValid = false;
        }

        return isValid;
      }

      // Form submit handler
      form.addEventListener('submit', function(e) {
        console.log('Submit event triggered');
        
        if (!validateFormOnSubmit()) {
          e.preventDefault();
          console.log('Form validation failed - preventing submit');
          
          // Scroll to first error
          const firstError = form.querySelector('.is-invalid');
          if (firstError) {
            firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
            firstError.focus();
          }
        } else {
          console.log('Form validation passed');
        }
      });

      // Reset button handler
      if (resetBtn) {
        resetBtn.addEventListener('click', function() {
          const fields = form.querySelectorAll('input, select');
          fields.forEach(field => {
            field.classList.remove('is-invalid', 'is-valid');
          });
          
          const errors = form.querySelectorAll('.error-message');
          errors.forEach(error => {
            error.style.display = 'none';
          });
        });
      }

      // Real-time validation as user types
      const inputs = form.querySelectorAll('input');
      inputs.forEach(input => {
        input.addEventListener('input', function() {
          if (this.classList.contains('is-invalid')) {
            const value = this.value.trim();
            if (value) {
              this.classList.remove('is-invalid');
              this.classList.add('is-valid');
              const errorElement = document.getElementById(this.id + '-error');
              if (errorElement) {
                errorElement.style.display = 'none';
              }
            }
          }
        });
      });

      console.log('Form validation initialized successfully');
    });
  script(src='../javascript/user.js')