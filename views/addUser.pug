extends layout.pug 

block styles 
  link(rel='stylesheet' href='/css/add-user.css')
  
block content 
  .user-form-container
    .form-header
      h2
        i.fas.fa-user-plus
        | Register New Sales Agent
      p.instruction Create a new sales agent account

    form#addUser(action='/addUser' method='post' novalidate)
      .form-grid
        if error
          .alert.alert-danger
            i.fas.fa-exclamation-circle
            | #{error}
        
        .form-group
          label(for='name')
            i.fas.fa-user
            | Full Name
          input#name.form-control(type='text' name='name' placeholder='Enter full name' required)
          .error-message#name-error Please enter a valid full name (2-100 characters)
        
        .form-group
          label(for='email')
            i.fas.fa-envelope
            | Email Address
          input#email.form-control(type="email", name="email", placeholder="Enter email address" required)
          .error-message#email-error Please enter a valid email address
        
        .form-group
          label(for='tel')
            i.fas.fa-phone
            | Phone Number
          input#tel.form-control(type="text", name="tel", placeholder="+256 XXX XXX XXX" required)
          .error-message#tel-error Please enter a valid phone number (9-10 digits)
        
        .form-group
          label(for='nin')
            i.fas.fa-id-card
            | NIN Number
          input#nin.form-control(type='text' name='nin' placeholder='Enter NIN number' required)
          .error-message#nin-error Please enter a valid NIN number
        
        .form-group
          label(for='address')
            i.fas.fa-home
            | Address
          input#address.form-control(type='text' name='address' placeholder='Enter full address' required)
          .error-message#address-error Please enter a valid address
        
        .form-group
          label(for='username')
            i.fas.fa-user-circle
            | Username
          input#username.form-control(type='text' name='username' placeholder='Choose a username' required)
          .error-message#username-error Please enter a username (3-20 characters)
        
        .form-group
          label(for='password')
            i.fas.fa-lock
            | Password
          input#password.form-control(type='password' name='password' placeholder='Create password' required)
          .error-message#password-error Password must be at least 6 characters
          .password-strength
            .strength-bar#passwordStrength
        
        .form-group
          label(for='confirmPassword')
            i.fas.fa-lock
            | Confirm Password
          input#confirmPassword.form-control(type='password' name='confirmPassword' placeholder='Confirm password' required)
          .error-message#confirmPassword-error Passwords do not match
        
        .form-group
          label(for='date')
            i.fas.fa-calendar-alt
            | Registration Date
          input#date.form-control(type='date' name='date' required)
          .error-message#date-error Please select a valid date
      
      .form-actions
        button.btn.btn-secondary(type='reset' id='resetBtn')
          i.fas.fa-times
          | Cancel
        button.btn.btn-primary(type='submit')
          i.fas.fa-user-plus
          | Create Sales Agent