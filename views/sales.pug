extends layout.pug 
block styles 
  link(rel='stylesheet', href='../css/sales.css')
block content
  include sidebar.pug
  main.main-content
    .dashboarBody
      h3 Mayondo Wood And Furniture ltd
    if currentUser && currentUser.role === 'sales_agent'
      .welcome-container
        h4.fade-in Welcome 
          span.username.typewriter #{currentUser.username}!
        p.fade-in(style="animation-delay: 1.5s;") You're now logged in.
    // SUCCESS MODAL
    if success
      .modal.fade.show(tabindex='-1', style='display: block; background-color: rgba(0,0,0,0.5);')
        .modal-dialog.modal-dialog-centered
          .modal-content
            .modal-header.bg-success(style='bacground: #4c6444; color: #fff')
              h5.modal-title
                i.fas.fa-check-circle.me-2
                | Success!
              button.btn-close(type='button', onclick="closeMessageModal()")
            .modal-body
              p #{success}
            .modal-footer
              button.btn.btn-success(type='button', onclick="closeMessageModal()") OK

    // ERROR MODAL
    if error
      .modal.fade.show(tabindex='-1', style='display: block; background-color: rgba(0,0,0,0.5);')
        .modal-dialog.modal-dialog-centered
          .modal-content
            .modal-header.bg-danger.text-white
              h5.modal-title
                i.fas.fa-exclamation-circle.me-2
                | Error!
              button.btn-close(type='button', onclick="closeMessageModal()")
            .modal-body
              p #{error}
            .modal-footer
              button.btn.btn-danger(type='button', onclick="closeMessageModal()") OK

    // DELETE CONFIRMATION MODAL
    #deleteConfirmationModal.modal.fade(tabindex='-1', aria-labelledby='deleteConfirmationModalLabel', aria-hidden='true')
      .modal-dialog.modal-dialog-centered
        .modal-content
          .modal-header.bg-warning.text-dark
            h5.modal-title
              i.fas.fa-exclamation-triangle.me-2
              | Confirm Deletion
            button.btn-close(type='button', data-bs-dismiss='modal', aria-label='Close')
          .modal-body
            p Are you sure you want to delete this sale record?
            p.text-muted.small This action cannot be undone.
          .modal-footer
            button.btn.btn-secondary(type='button', data-bs-dismiss='modal') Cancel
            form#deleteForm(method='post', action='/deleteSale', style='display: inline;')
              input(type='hidden', name='id', id='deleteSaleId')
              button.btn.btn-danger(type='submit') Delete
    br
    section#dash-top.dash
      .row
        .col-md-3
          .dash-card
            .card-body
              i.fa-solid.fa-money-bill-trend-up
              h5.card-title Total Sales
              p.card-text Shs. #{dashboardMetrics && !isNaN(dashboardMetrics.totalSalesAll) ? dashboardMetrics.totalSalesAll.toLocaleString() : '0'}
              .breakdown
                small Raw: Shs. #{dashboardMetrics && !isNaN(dashboardMetrics.totalSalesRaw) ? dashboardMetrics.totalSalesRaw.toLocaleString() : '0'}
                br
                small Furniture: Shs. #{dashboardMetrics && !isNaN(dashboardMetrics.totalSalesFurniture) ? dashboardMetrics.totalSalesFurniture.toLocaleString() : '0'}
        .col-md-3
          .dash-card
            .card-body
              i.fa-solid.fa-phone-volume
              h5.card-title Total Orders
              p.card-text #{dashboardMetrics ? dashboardMetrics.totalOrders : '0'}
        .col-md-3
          .dash-card
            .card-body
              i.fa-solid.fa-scale-balanced
              h5.card-title Total Sold Products
              p.card-text #{dashboardMetrics && !isNaN(dashboardMetrics.totalSoldAll) ? dashboardMetrics.totalSoldAll : '0'} units
              .breakdown
                small Raw: #{dashboardMetrics && !isNaN(dashboardMetrics.totalSoldRaw) ? dashboardMetrics.totalSoldRaw : '0'}
                br
                small Furniture: #{dashboardMetrics && !isNaN(dashboardMetrics.totalSoldFurniture) ? dashboardMetrics.totalSoldFurniture : '0'}
        .col-md-3
          .dash-card
            .card-body
              i.fa-solid.fa-chart-pie
              h5.card-title Sales Distribution
              .distribution
                .raw-material
                  small Raw: #{dashboardMetrics && !isNaN(dashboardMetrics.rawPercentage) ? dashboardMetrics.rawPercentage : '0'}%
                .furniture
                  small Furniture: #{dashboardMetrics && !isNaN(dashboardMetrics.furniturePercentage) ? dashboardMetrics.furniturePercentage : '0'}%

      br
      br
      br

    
    #including.include
      .button-group
        a.btns(href='/addSale')
          i.fas.fa-plus-circle
          | Add Sale
        //- a#downloadExcel.btns
        //-   i.fas.fa-file-excel
        //-   | Download Excel
        a#downloadPdf.btns
          i.fas.fa-file-pdf
          | Download PDF
      
      .filter-section
        label.filter-label(for='productFilter') Filter by:
        select#productFilter.filter-dropdown
          option(value='all') All Products
          option(value='raw') Raw Products
          option(value='furniture') Furniture Products

      .filter-section.date-filter-container
        label.filter-label(for='startDate') From:
        input#startDate.filter-date(type='date')
        label.filter-label(for='endDate') To:
        input#endDate.filter-date(type='date')
        button#applyDateFilter.btns.small Apply
        button#clearDateFilter.btns.small Clear

      input#searchSale(type='search', placeholder='Search sales...')

    section
      table#salesTable.table-content
        thead.row-one
          tr
            th Customer Name
            th Customer Contact
            th Product Name
            th Product Type
            th Quantity
            th Unit Price UGX
            th Transport Check
            th Total Price UGX
            th Type of Payment
            th Date
            th Sales Agent 
            if currentUser && currentUser.role === 'manager'
              th Actions
        tbody.row-others
          if items && items.length
            each item in items
              tr
                td #{item.name}
                td #{item.contact}
                td #{item.nproduct}
                td #{item.tproduct}
                td #{item.quantity}
                td #{(item.unitPrice && !isNaN(item.unitPrice)) ? item.unitPrice.toLocaleString() : '0'}
                td #{item.transportCheck ? 'Yes' : 'No'}
                td #{(item.totalPrice && !isNaN(item.totalPrice)) ? Math.round(item.totalPrice).toLocaleString() : '0'}
                td #{item.payment}
                td #{new Date(item.date).toLocaleDateString()}
                td #{item.agentName}
                if currentUser && currentUser.role === 'manager'
                  td.actions
                    a.btn-icon(href=`/editSales/${item._id}`, title='Edit')
                      i.fas.fa-edit
                    button.btn-icon(type='button', title='Delete', onclick=`showDeleteConfirmation('${item._id}')`)
                      i.fas.fa-trash
                    form(method='post', action=`/getReceipt/${item._id}`, style='display:inline')
                      input(type='hidden', name='id', value=item._id)
                      button.btn-icon(type='submit', title='Receipt')
                        i.fas.fa-file-invoice
          else
            tr
              td(colspan=(currentUser && currentUser.role === 'manager' ? 12 : 11), style='text-align:center;')
                | No sales records found
      br
      br
      h5#notFound Not Found!
    footer
      p © 2025 Mayondo Wood & Furniture Ltd. All rights reserved.
      p Designed By Kirabo Rebecca.
  script(src='https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js')
  script(src='https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js')
  script(src='https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js')
  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js')
  script(src='/javascript/sales.js')