extends layout.pug 
block styles
  link(rel='stylesheet' href='../css/add-stock.css')
block content 
  include sidebar.pug
  main.main-content
    nav.navbar.bg-body-tertiary.dashboard-header
      .container-fluid.d-flex.justify-content-end.align-items-center
        .d-flex.align-items-center
          a.logoutBtn(href='/index') Logout
    
    .stock-form-container
      form#addStock(action='/addStock' method='post' novalidate)
        h2 Add Stock Here!
        
        .form-group
          label(for='pdtname') Product Name
          br
          input#pdtname.form-control(type='text' name='pdtname' required)
          .error-message#pdtname-error Please enter a valid product name
          br
        
        .form-group
          label(for='pdttype') Type of Product
          br
          select#tproduct.form-control(name="pdttype" required)
            option(value="" disabled selected) Select Type of Product 
            option(value="Raw") Raw 
            option(value="Furniture") Furniture 
          .error-message#pdttype-error Please select a product type
          br
        
        .form-group
          label(for='pdtquantity1') Total Quantity
          br
          input#pdtquantity1.form-control(type='number' name='pdtquantity1' min="1" required)
          .error-message#pdtquantity1-error Please enter a valid quantity (minimum 1)
          br
        
        .form-group
          label(for='pdtquantity') Remaining Quantity
          br
          input#pdtquantity.form-control(type='number' name='pdtquantity' min="0" required)
          .error-message#pdtquantity-error Please enter a valid quantity (cannot be negative)
          br
        
        .form-group
          label(for='cprice') Cost Price
          br
          input#cprice.form-control(type='number' name='cprice' step="0.01" min="0")
          .error-message#cprice-error Please enter a valid cost price
          br
        
        .form-group
          label(for='pdtprice') Product Price
          br
          input#pdtprice.form-control(type='number' name='pdtprice' step="0.01" min="0" required)
          .error-message#pdtprice-error Please enter a valid product price
          br
        
        .form-group
          label(for='supplier') Supplier Name
          br
          input#supplier.form-control(type='text' name='supplier')
          .error-message#supplier-error Please enter a supplier name
          br
        
        .form-group
          label(for='supplierContact') Supplier Contact
          br
          input#supplierContact.form-control(type='text' name='supplierContact' required pattern="[0-9+\-\s()]+" title="Please enter a valid phone number")
          .error-message#supplierContact-error Please enter a valid supplier contact
          br
        
        .form-group
          label(for='quality') Quality
          br
          select#quality.form-control(name="quality" required)
            option(value="" disabled selected) Select Quality
            option(value="Premium") Premium
            option(value="Good") Good
            option(value="Fair") Fair
            option(value="Poor") Poor
          .error-message#quality-error Please select a quality level
          br
        
        .form-group
          label(for='date') Date
          br
          input#date.form-control(type='date' name='date' required)
          .error-message#date-error Please select a date
          br
        
        .add
          button.btns(type='submit') Save
          button.btns(type='reset' id='resetBtn') Cancel

  script.
    document.addEventListener('DOMContentLoaded', function() {
      const costPriceInput = document.getElementById('cprice');
      const productPriceInput = document.getElementById('pdtprice');
      
      if (costPriceInput && productPriceInput) {
        costPriceInput.addEventListener('input', function() {
          const costPrice = parseFloat(this.value) || 0;
          const productPrice = Math.round(costPrice * 1.5);
          productPriceInput.value = productPrice;
        });
      }
    });
  script(src='../javascript/stock.js')