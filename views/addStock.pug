extends layout.pug

block styles
  link(rel='stylesheet' href='/css/add-stock.css')

block content 
  main.main-content
    .stock-form-container
      .form-header
        h2
          i.fas.fa-boxes
          | Add Stock
        p.instruction Fill in the product details below

      form#addStock(action='/addStock' method='post' novalidate)
        .form-grid
          .form-group
            label(for='pdtname')
              i.fas.fa-tag
              | Product Name
            input#pdtname.form-control(type='text' name='pdtname' placeholder='Enter product name' required)
            .error-message#pdtname-error Please enter a valid product name (2-100 characters)
          
          .form-group
            label(for='pdttype')
              i.fas.fa-list
              | Type of Product
            select#tproduct.form-control(name="pdttype" required)
              option(value="" disabled selected) Select Type of Product 
              option(value="Raw") Raw 
              option(value="Furniture") Furniture 
            .error-message#pdttype-error Please select a product type
          
          .form-group
            label(for='pdtquantity1')
              i.fas.fa-layer-group
              | Total Quantity
            input#pdtquantity1.form-control(type='number' name='pdtquantity1' min="1" placeholder="0" required)
            .error-message#pdtquantity1-error Please enter a valid quantity (minimum 1)
          
          .form-group
            label(for='pdtquantity')
              i.fas.fa-box-open
              | Remaining Quantity
            input#pdtquantity.form-control(type='number' name='pdtquantity' min="0" placeholder="0" required)
            .error-message#pdtquantity-error Please enter a valid quantity (cannot be negative)
          
          .form-group
            label(for='cprice')
              i.fas.fa-money-bill-wave
              | Cost Price ($)
            input#cprice.form-control(type='number' name='cprice' step="0.01" min="0" placeholder="0.00")
            .error-message#cprice-error Please enter a valid cost price
          
          .form-group
            label(for='pdtprice')
              i.fas.fa-dollar-sign
              | Product Price ($)
            input#pdtprice.form-control(type='number' name='pdtprice' step="0.01" min="0" placeholder="0.00" required)
            .error-message#pdtprice-error Please enter a valid product price
          
          .form-group
            label(for='supplier')
              i.fas.fa-truck
              | Supplier Name
            input#supplier.form-control(type='text' name='supplier' placeholder='Enter supplier name')
            .error-message#supplier-error Please enter a supplier name (2-100 characters)
          
          .form-group
            label(for='supplierContact')
              i.fas.fa-phone
              | Supplier Contact
            input#supplierContact.form-control(type='text' name='supplierContact' placeholder='+1 (555) 123-4567' required pattern="[0-9+\-\s()]+" title="Please enter a valid phone number")
            .error-message#supplierContact-error Please enter a valid supplier contact
          
          .form-group
            label(for='quality')
              i.fas.fa-star
              | Quality
            select#quality.form-control(name="quality" required)
              option(value="" disabled selected) Select Quality
              option(value="Premium") Premium
              option(value="Good") Good
              option(value="Fair") Fair
              option(value="Poor") Poor
            .error-message#quality-error Please select a quality level
          
          .form-group
            label(for='date')
              i.fas.fa-calendar-alt
              | Date
            input#date.form-control(type='date' name='date' required)
            .error-message#date-error Please select a date
        
        .form-actions
          button.btn.btn-secondary(type='reset' id='resetBtn')
            i.fas.fa-times
            | Cancel
          button.btn.btn-primary(type='submit')
            i.fas.fa-save
            | Save Product

  script.
    document.addEventListener('DOMContentLoaded', function() {
      // Cost price auto-calculation
      const costPriceInput = document.getElementById('cprice');
      const productPriceInput = document.getElementById('pdtprice');
      
      if (costPriceInput && productPriceInput) {
        costPriceInput.addEventListener('input', function() {
          const costPrice = parseFloat(this.value) || 0;
          const productPrice = Math.round(costPrice * 1.5);
          productPriceInput.value = productPrice;
        });
      }

      // Form Validation
      const form = document.getElementById('addStock');
      const resetBtn = document.getElementById('resetBtn');

      if (!form) return;

      // Get all form fields
      const fields = {
        pdtname: document.getElementById('pdtname'),
        pdttype: document.getElementById('tproduct'),
        pdtquantity1: document.getElementById('pdtquantity1'),
        pdtquantity: document.getElementById('pdtquantity'),
        cprice: document.getElementById('cprice'),
        pdtprice: document.getElementById('pdtprice'),
        supplier: document.getElementById('supplier'),
        supplierContact: document.getElementById('supplierContact'),
        quality: document.getElementById('quality'),
        date: document.getElementById('date')
      };

      // Validation functions
      const validators = {
        pdtname: (value) => value.trim().length >= 2 && value.trim().length <= 100,
        pdttype: (value) => value && value !== "",
        pdtquantity1: (value) => value && parseInt(value) > 0,
        pdtquantity: (value) => value && parseInt(value) >= 0,
        cprice: (value) => value && parseFloat(value) >= 0,
        pdtprice: (value) => value && parseFloat(value) >= 0,
        supplier: (value) => value.trim().length >= 2 && value.trim().length <= 100,
        supplierContact: (value) => {
          const phoneRegex = /^[0-9+\-\s()]{9,15}$/;
          return phoneRegex.test(value.trim());
        },
        quality: (value) => value && value !== "",
        date: (value) => value && !isNaN(new Date(value).getTime())
      };

      // Error messages
      const errorMessages = {
        pdtname: "Please enter a valid product name (2-100 characters)",
        pdttype: "Please select a product type",
        pdtquantity1: "Please enter a valid total quantity (minimum 1)",
        pdtquantity: "Please enter a valid remaining quantity (cannot be negative)",
        cprice: "Please enter a valid cost price",
        pdtprice: "Please enter a valid product price",
        supplier: "Please enter a valid supplier name (2-100 characters)",
        supplierContact: "Please enter a valid phone number (9-15 digits with +, -, (), or spaces)",
        quality: "Please select a quality level",
        date: "Please select a valid date"
      };

      // Show error function
      function showError(fieldName, message) {
        const field = fields[fieldName];
        const errorElement = document.getElementById(fieldName + '-error');

        if (field && errorElement) {
          field.classList.add('is-invalid');
          field.classList.remove('is-valid');
          errorElement.textContent = message;
          errorElement.style.display = 'block';
        }
      }

      // Show success function
      function showSuccess(fieldName) {
        const field = fields[fieldName];
        const errorElement = document.getElementById(fieldName + '-error');

        if (field && errorElement) {
          field.classList.remove('is-invalid');
          field.classList.add('is-valid');
          errorElement.style.display = 'none';
        }
      }

      // Validate single field
      function validateField(fieldName) {
        const field = fields[fieldName];
        if (!field) return true;

        const value = field.value;
        const isValid = validators[fieldName](value);

        if (!isValid) {
          showError(fieldName, errorMessages[fieldName]);
          return false;
        } else {
          showSuccess(fieldName);
          return true;
        }
      }

      // Validate entire form
      function validateForm() {
        let isValid = true;

        Object.keys(fields).forEach(fieldName => {
          if (!validateField(fieldName)) {
            isValid = false;
          }
        });

        // Remaining quantity should not exceed total quantity
        const totalQty = parseInt(fields.pdtquantity1.value);
        const remainingQty = parseInt(fields.pdtquantity.value);

        if (totalQty && remainingQty && remainingQty > totalQty) {
          showError('pdtquantity', 'Remaining quantity cannot exceed total quantity');
          isValid = false;
        }

        return isValid;
      }

      // Add event listeners to all fields for real time validation
      Object.keys(fields).forEach(fieldName => {
        const field = fields[fieldName];
        if (field) {
          field.addEventListener('blur', () => validateField(fieldName));
          field.addEventListener('input', () => {
            if (field.classList.contains('is-invalid')) {
              validateField(fieldName);
            }
          });
        }
      });

      // Form submit event
      form.addEventListener('submit', function (e) {
        e.preventDefault();

        if (validateForm()) {
          console.log('Form is valid, submitting...');
          this.submit();
        } else {
          const firstError = form.querySelector('.is-invalid');
          if (firstError) {
            firstError.scrollIntoView({
              behavior: 'smooth',
              block: 'center'
            });
            firstError.focus();
          }
        }
      });

      // Reset button functionality
      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          Object.keys(fields).forEach(fieldName => {
            const field = fields[fieldName];
            const errorElement = document.getElementById(fieldName + '-error');

            if (field && errorElement) {
              field.classList.remove('is-invalid', 'is-valid');
              errorElement.style.display = 'none';
            }
          });
        });
      }

      // Additional validation for quantity comparison
      if (fields.pdtquantity1 && fields.pdtquantity) {
        fields.pdtquantity1.addEventListener('change', function () {
          const totalQty = parseInt(this.value);
          const remainingQty = parseInt(fields.pdtquantity.value);

          if (totalQty && remainingQty && remainingQty > totalQty) {
            showError('pdtquantity', 'Remaining quantity cannot exceed total quantity');
          }
        });

        fields.pdtquantity.addEventListener('change', function () {
          const totalQty = parseInt(fields.pdtquantity1.value);
          const remainingQty = parseInt(this.value);

          if (totalQty && remainingQty && remainingQty > totalQty) {
            showError('pdtquantity', 'Remaining quantity cannot exceed total quantity');
          }
        });
      }

      console.log("Form validation initialized");
    });

  script(src="../javascript/stock.js")